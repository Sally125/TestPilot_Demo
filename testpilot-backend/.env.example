# ===== DeepSeek API 配置 =====
# DeepSeek API Key（必填，用于需求分析与脚本生成）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API Base URL（可选，默认为官方地址）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# ===== 服务配置 =====
# 服务监听端口
APP_PORT=8000

# 是否开启调试模式
DEBUG=true

# ===== Playwright 执行配置 =====
# 被测应用 URL（可选，执行脚本时使用）
TARGET_APP_URL=http://localhost:3000

# 浏览器类型（chromium / firefox / webkit）
BROWSER_TYPE=chromium

# 浏览器超时时间（毫秒）
BROWSER_TIMEOUT=30000

# 登录态 storageState 文件路径（可选）
STORAGE_STATE_PATH=

# ===== 测试账号配置（可选，用于登录态注入）=====
TEST_USERNAME=
TEST_PASSWORD=
LOGIN_URL=
