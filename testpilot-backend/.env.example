# ===== DeepSeek API 配置（必填）=====
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.kukuit.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ===== 服务配置 =====
APP_PORT=8000
DEBUG=true

# ===== Playwright 执行配置 =====
TARGET_APP_URL=https://demo.playwright.dev/todomvc/
BROWSER_TYPE=chromium
BROWSER_TIMEOUT=60000
STORAGE_STATE_PATH=

# ===== 测试账号配置（可选）=====
TEST_USERNAME=
TEST_PASSWORD=
LOGIN_URL=

# ===== 代理配置（可选，若网络受限）=====
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=